{
  "name": "sl88",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --cwd apps/api src/app/index.ts",
    "build": "bun run --cwd apps/web build",
    "format": "vp fmt",
    "lint": "vp lint",
    "typecheck": "vp check --no-fmt --no-lint",
    "check": "vp check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test:contract": "bun test apps/api/tests/contract"
  },
  "devDependencies": {
    "drizzle-kit": "latest",
    "typescript": "^5.8.0",
    "vite-plus": "latest"
  }
}
