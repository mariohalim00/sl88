# Environment Configuration
#
# Copy this file to .env and fill in your local values.
# Never commit .env to source control.

# PostgreSQL connection string (must match docker-compose.yml defaults)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sl88_dev

# Port the Elysia API server listens on
API_PORT=3000

# Shopify Storefront API proxy configuration
SHOPIFY_STORE_DOMAIN=your-shop.myshopify.com
SHOPIFY_STOREFRONT_API_VERSION=2026-01
SHOPIFY_STOREFRONT_ACCESS_TOKEN=replace-with-storefront-access-token
